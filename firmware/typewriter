//A Small Typewriter demo for the muxcard project using partial refresh to display each word one by one.

#include <GxEPD2_BW.h>
#include <Fonts/FreeMonoBold12pt7b.h>

#define EPD_CS    8
#define EPD_DC    5
#define EPD_RST   4
#define EPD_BUSY  3

GxEPD2_BW<GxEPD2_154_D67, GxEPD2_154_D67::HEIGHT> display(
  GxEPD2_154_D67(EPD_CS, EPD_DC, EPD_RST, EPD_BUSY)
);

const char* text =
  "The future belongs to those who build it.";

String buffer = "";
String currentLine = "";

const int margin = 20;
const int maxWidth = 180;
const int startY = 50;
const int lineHeight = 24;

void setup()
{
  SPI.begin(6, -1, 7, EPD_CS);
  display.init(115200);

  display.setRotation(3);
  display.setFont(&FreeMonoBold12pt7b);
  display.setTextColor(GxEPD_BLACK);

  typeText();

  display.hibernate();
}

void loop() {}

uint16_t measureWidth(String str)
{
  int16_t x1, y1;
  uint16_t w, h;
  display.getTextBounds(str, 0, 0, &x1, &y1, &w, &h);
  return w;
}

void redrawText()
{
  display.setPartialWindow(0, 0, 200, 200);

  display.firstPage();
  do {
    display.fillScreen(GxEPD_WHITE);

    int y = startY;
    String line = "";

    for (int i = 0; i < buffer.length(); i++)
    {
      char c = buffer[i];

      if (c == '\n')
      {
        display.setCursor(margin, y);
        display.print(line);

        line = "";
        y += lineHeight;
      }
      else
      {
        line += c;
      }
    }

    if (line.length() > 0)
    {
      display.setCursor(margin, y);
      display.print(line);
    }

  } while (display.nextPage());
}

void typeText()
{
  int i = 0;

  while (text[i] != '\0')
  {
    String word = "";

    while (text[i] != ' ' && text[i] != '\0')
    {
      word += text[i];
      i++;
    }

    if (text[i] == ' ')
    {
      word += ' ';
      i++;
    }

    if (measureWidth(currentLine + word) > maxWidth)
    {
      buffer += "\n";
      currentLine = "";
    }

    buffer += word;
    currentLine += word;

    redrawText();
  }
}
